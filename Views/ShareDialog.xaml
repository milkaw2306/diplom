<Window x:Class="Diplom_zxc.Views.ShareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diplom_zxc.ViewModels"
        Title="Поделиться" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:ShareViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                CornerRadius="10"
                Padding="30"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="🔗 Поделиться" FontSize="24" FontWeight="Bold" 
                          Margin="0,0,0,10"
                          Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <TextBlock Text="{Binding SharedItemName, StringFormat='Объект: {0}'}" 
                          FontSize="14" Margin="0,0,0,20"
                          Foreground="{DynamicResource MaterialDesignBody}"/>

                <!-- Тип шаринга -->
                <Border Background="{DynamicResource MaterialDesignPaper}" 
                       Padding="15" CornerRadius="8" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Тип доступа:" FontWeight="Bold" Margin="0,0,0,10"/>

                        <RadioButton Content="📁 Поделиться папкой" 
                                    IsChecked="{Binding IsFolderShare}"
                                    GroupName="ShareType"
                                    Margin="0,0,0,5"
                                    Foreground="{DynamicResource MaterialDesignBody}"/>

                        <RadioButton Content="🖼️ Поделиться фотографией" 
                                    IsChecked="{Binding IsPhotoShare}"
                                    GroupName="ShareType"
                                    Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>
                </Border>

                <!-- Настройки срока действия -->
                <Border Background="{DynamicResource MaterialDesignPaper}" 
                       Padding="15" CornerRadius="8" Margin="0,0,0,15">
                    <StackPanel>
                        <CheckBox Content="⏰ Ограничить срок действия" 
                                 IsChecked="{Binding HasExpiry}"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource MaterialDesignBody}"/>

                        <StackPanel IsEnabled="{Binding HasExpiry}">
                            <TextBlock Text="Срок действия:" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding ExpiryOptions}" 
                                     SelectedItem="{Binding SelectedExpiryOption}"
                                     DisplayMemberPath="Name"
                                     Height="35"
                                     Background="{DynamicResource MaterialDesignCardBackground}"/>

                            <TextBlock Margin="0,10,0,0"
                                      Foreground="{DynamicResource MaterialDesignBody}">
                                <Run Text="Действует до: "/>
                                <Run Text="{Binding ExpiryDate, StringFormat='dd.MM.yyyy HH:mm'}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Кнопка создания ссылки -->
                <Button Content="🔗 Создать ссылку" 
                       Command="{Binding CreateShareLinkCommand}"
                       Height="45" FontSize="14" FontWeight="Bold"
                       Background="{DynamicResource PrimaryHueMidBrush}"
                       Foreground="White" BorderThickness="0"
                       Margin="0,0,0,15"
                       Visibility="{Binding IsLinkCreated, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"/>

                <!-- Созданная ссылка -->
                <Border Background="{DynamicResource MaterialDesignPaper}" 
                       Padding="15" CornerRadius="8" Margin="0,0,0,15"
                       Visibility="{Binding IsLinkCreated, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="✅ Ссылка создана!" FontWeight="Bold" 
                                  Margin="0,0,0,10" Foreground="Green"/>

                        <TextBlock Text="Код доступа:" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ShareCode, UpdateSourceTrigger=PropertyChanged}"
                                Height="40" IsReadOnly="True"
                                FontSize="18" FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                Background="{DynamicResource MaterialDesignCardBackground}"
                                Margin="0,0,0,10"
                                BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                BorderThickness="2"/>

                        <TextBlock Text="Ссылка скопирована в буфер обмена!" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                  FontSize="12" Margin="0,0,0,10"
                                  HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="📋 Копировать" 
                                   Command="{Binding CopyLinkCommand}"
                                   Height="35" Width="120" Margin="5"
                                   Background="{DynamicResource PrimaryHueMidBrush}"
                                   Foreground="White" BorderThickness="0"
                                   Cursor="Hand"/>

                            <Button Content="📧 Отправить" 
                                   Command="{Binding ShareViaEmailCommand}"
                                   Height="35" Width="120" Margin="5"
                                   Background="{DynamicResource PrimaryHueMidBrush}"
                                   Foreground="White" BorderThickness="0"
                                   Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Статус -->
                <TextBlock Text="{Binding StatusText}" 
                          Foreground="{DynamicResource MaterialDesignBody}"
                          TextWrapping="Wrap" Margin="0,5"
                          HorizontalAlignment="Center"/>

                <!-- Ошибки -->
                <TextBlock Text="{Binding ErrorMessage}" 
                          Foreground="Red" 
                          Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                          TextWrapping="Wrap" Margin="0,5"
                          HorizontalAlignment="Center"/>

                <!-- Прогресс -->
                <ProgressBar IsIndeterminate="{Binding IsCreating}" 
                            Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibilityConverter}}"
                            Height="20" Margin="0,10"
                            Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Закрыть" 
                           Command="{Binding CloseWindowCommand}"
                           Height="35" Width="100" Margin="5"
                           Background="Transparent"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           BorderBrush="{DynamicResource MaterialDesignDivider}"
                           BorderThickness="1"
                           Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>