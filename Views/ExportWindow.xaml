<Window x:Class="Diplom_zxc.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diplom_zxc.ViewModels"
        Title="Экспорт фотографий" 
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <viewModels:ExportViewModel/>
    </Window.DataContext>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <StackPanel Margin="30">
            <TextBlock Text="Экспорт фотографий" FontSize="24" FontWeight="Bold" 
                      Margin="0,0,0,20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

            <!-- Путь экспорта -->
            <TextBlock Text="Папка для экспорта" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding ExportPath, UpdateSourceTrigger=PropertyChanged}"
                        Height="35" IsReadOnly="True"
                        Background="{DynamicResource MaterialDesignCardBackground}"/>

                <Button Grid.Column="1" Content="Обзор" 
                       Command="{Binding BrowseFolderCommand}"
                       Height="35" Width="80" Margin="5,0,0,0"
                       Background="{DynamicResource PrimaryHueMidBrush}"
                       Foreground="White" BorderThickness="0"/>
            </Grid>

            <!-- Тип экспорта -->
            <TextBlock Text="Тип экспорта" Margin="0,10,0,5"/>
            <ComboBox ItemsSource="{Binding ExportTypes}" 
                     SelectedItem="{Binding SelectedExportType}"
                     DisplayMemberPath="Name"
                     Height="35" Margin="0,0,0,20"/>

            <!-- Прогресс -->
            <ProgressBar IsIndeterminate="{Binding IsExporting}" 
                        Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibilityConverter}}"
                        Height="20" Margin="0,10"
                        Foreground="{DynamicResource PrimaryHueMid