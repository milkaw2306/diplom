<Window x:Class="Diplom_zxc.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diplom_zxc.ViewModels"
        Title="Diplom_zxc - Регистрация" 
        Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:RegisterViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                CornerRadius="10"
                Padding="30"
                Margin="20"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Diplom_zxc" FontSize="28" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,10"
                              Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                    <TextBlock Text="Регистрация" FontSize="18" 
                              HorizontalAlignment="Center" Margin="0,0,0,20"
                              Foreground="{DynamicResource MaterialDesignBody}"/>

                    <TextBlock Text="Имя пользователя *" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                            Height="35" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Полное имя" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                            Height="35" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Email *" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                            Height="35" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Пароль *" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox"
                                Height="35" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Подтвердите пароль *" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                Height="35" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ErrorMessage}" 
                              Foreground="Red" 
                              Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                              Margin="0,5" TextWrapping="Wrap"/>

                    <Button Content="Зарегистрироваться" 
                           Command="{Binding RegisterCommand}"
                           Height="40" FontSize="14"
                           Background="{DynamicResource PrimaryHueMidBrush}"
                           Foreground="White"
                           BorderThickness="0"
                           Margin="0,10"/>

                    <Button Content="Уже есть аккаунт? Войти" 
                           Command="{Binding GoToLoginCommand}"
                           Height="35" FontSize="12"
                           Background="Transparent"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           BorderBrush="{DynamicResource MaterialDesignDivider}"
                           BorderThickness="1"
                           Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>