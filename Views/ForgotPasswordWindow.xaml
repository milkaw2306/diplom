<Window x:Class="Diplom_zxc.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diplom_zxc.ViewModels"
        Title="Diplom_zxc - Восстановление пароля" 
        Height="450" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:ForgotPasswordViewModel/>
    </Window.DataContext>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Border Background="{DynamicResource MaterialDesignCardBackground}" 
                CornerRadius="10"
                Padding="30"
                Margin="20"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Восстановление пароля" FontSize="22" FontWeight="Bold" 
                          HorizontalAlignment="Center" Margin="0,0,0,20"
                          Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <!-- Шаг 1 -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCodeSent}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Введите email для восстановления" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                            Height="35" FontSize="14" Margin="0,0,0,15"/>

                    <Button Content="Отправить код" 
                           Command="{Binding SendCodeCommand}"
                           Height="40" FontSize="14"
                           Background="{DynamicResource PrimaryHueMidBrush}"
                           Foreground="White"
                           BorderThickness="0"/>
                </StackPanel>

                <!-- Шаг 2 -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCodeSent}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="На ваш email отправлен код подтверждения" 
                              TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Text="6-значный код" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ResetCode, UpdateSourceTrigger=PropertyChanged}"
                            Height="35" FontSize="14" MaxLength="6" Margin="0,0,0,10"/>

                    <TextBlock Text="Новый пароль" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                Height="35" FontSize="14" Margin="0,0,0,15"/>

                    <Button Content="Сменить пароль" 
                           Command="{Binding ResetPasswordCommand}"
                           Height="40" FontSize="14"
                           Background="{DynamicResource PrimaryHueMidBrush}"
                           Foreground="White"
                           BorderThickness="0"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" 
                          Foreground="Red"
                          Margin="0,10,0,0" TextWrapping="Wrap"/>

                <Button Content="Вернуться ко входу" 
                       Command="{Binding GoToLoginCommand}"
                       Height="35" FontSize="12"
                       Background="Transparent"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       BorderBrush="{DynamicResource MaterialDesignDivider}"
                       BorderThickness="1"
                       Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>