<Window x:Class="Diplom_zxc.Views.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diplom_zxc.ViewModels"
        Title="Импорт фотографий" 
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <viewModels:ImportViewModel/>
    </Window.DataContext>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <StackPanel Margin="30">
            <TextBlock Text="Импорт фотографий" FontSize="24" FontWeight="Bold" 
                      Margin="0,0,0,20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

            <!-- Drag & Drop зона -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" 
                    BorderThickness="2" 
                    CornerRadius="8" 
                    Height="150"
                    Background="{DynamicResource MaterialDesignCardBackground}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Перетащите файлы и папки сюда" 
                              HorizontalAlignment="Center" FontSize="16"/>
                    <TextBlock Text="или используйте кнопки ниже" 
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>
            </Border>

            <!-- Кнопки импорта -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button Content="Импорт папки" 
                       Command="{Binding ImportFolderCommand}"
                       Height="40" Width="150" Margin="5"
                       Background="{DynamicResource PrimaryHueMidBrush}"
                       Foreground="White" BorderThickness="0"/>

                <Button Content="Импорт файлов" 
                       Command="{Binding ImportFilesCommand}"
                       Height="40" Width="150" Margin="5"
                       Background="{DynamicResource PrimaryHueMidBrush}"
                       Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <!-- Прогресс импорта -->
            <Border Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    Padding="15" CornerRadius="4" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,0,0,10"
                              Foreground="{DynamicResource MaterialDesignBody}"/>

                    <ProgressBar Value="{Binding ProgressValue}" 
                               Maximum="{Binding TotalFiles}"
                               Height="20"
                               IsIndeterminate="{Binding IsImporting}"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                    <TextBlock Text="{Binding CurrentFile}" 
                              TextTrimming="CharacterEllipsis" Margin="0,5,0,0"
                              Foreground="{DynamicResource MaterialDesignBody}"/>

                    <Button Content="Отмена" 
                           Command="{Binding CancelImportCommand}"
                           Height="30" HorizontalAlignment="Right"
                           Background="Transparent"
                           Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>